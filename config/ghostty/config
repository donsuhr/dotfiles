
font-family = "RobotoMono Nerd Font"
font-style = "Light"
font-size = 13

theme = nord

font-feature = -liga
macos-non-native-fullscreen = true
adjust-cell-height = 2

window-padding-x = 0
window-padding-y = 0
window-padding-balance = true
window-padding-color = background
window-width = 80
window-height = 24
window-save-state = 'never'

env = ITERM_PROFILE = 'dark'
